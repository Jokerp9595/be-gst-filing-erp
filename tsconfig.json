{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2017",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "lib": ["es2015"],
  "include": [
    "src/*",
    "package.json"
  ],
  "exclude": [
    "nswag",
    "dist",
    "node_modules"
  ],
  "typescript.tsserver.experimental.enableProjectDiagnostics": true
}